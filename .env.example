# Copy this file to .env and fill in the two required values.
# Both services share this file. docker-compose.yml already sets
# DATABASE_URL, SERVER_PORT, and MANAGEMENT_SERVICE_URL, so you
# don't need them here when running via docker-compose.

# ── Required ────────────────────────────────────────────────────────────────────

# Telegram bot token from https://t.me/BotFather
TELEGRAM_BOT_TOKEN=

# Shared secret that authenticates internal calls between the two services.
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=

# ── Optional ─────────────────────────────────────────────────────────────────────

# Comma-separated Telegram user IDs allowed to use the /trigger admin command.
# SERVICE_ADMIN_IDS=123456789,987654321

# Cron schedules (evaluated in TIMEZONE below).
# CRON_DAY_BEFORE=0 20 * * *
# CRON_DAY_AFTER=0 8 * * *
# CRON_WEEKLY_REMINDER=0 10 * * 1

# TIMEZONE=UTC
# LOG_LEVEL=INFO


# ── sports-booking-service ───────────────────────────────────────────────────────

# Eversports account credentials (required if running sports-booking-service).
# EVERSPORTS_EMAIL=
# EVERSPORTS_PASSWORD=

# Eversports legacy numeric user ID (required for fetching bookings).
# Find it by logging into eversports.de, opening browser DevTools → Network tab,
# and looking for a request to /api/user/activities?userId=<number>.
# EVERSPORTS_USER_ID=

# Eversports facility ID (numeric, visible in the venue page URL on eversports.de,
# Required for GET /api/v1/eversports/games.
# EVERSPORTS_FACILITY_ID=76443

# Comma-separated numeric court IDs. Required for GET /api/v1/eversports/games.
# Find them in the courts[]= parameters of the /api/slot network request in browser DevTools.
# EVERSPORTS_COURT_IDS=77385,77386,77387,77388,77389,77390,77391,77393,77392

# Facility UUID for booking creation (POST /api/v1/eversports/matches).
# Find it in the facilityUuid field of the /checkout/api/payableitem/courtbooking
# request body in browser DevTools. Has a built-in default for the configured venue.
# EVERSPORTS_FACILITY_UUID=6266968c-b0fd-4115-ad3b-ae225cc880f1

# Sport UUID for booking creation. Defaults to the Eversports squash UUID.
# Only change this if you are booking a different sport.
# EVERSPORTS_SPORT_UUID=b388b6e6-69de-11e8-bdc6-02bd505aa7b2

# URL path for the debug-page diagnostic endpoint. Change if your account uses a
# locale prefix (e.g. /de/user/bookings). Default: /user/bookings
# EVERSPORTS_BOOKINGS_PATH=/user/bookings

# ── Local development only (not needed when using docker-compose) ────────────────

# Required for squash-games-management when running outside Docker:
# DATABASE_URL=postgres://squash_bot:squash_bot@localhost:7432/squash_bot

# Required for telegram-squash-bot when running outside Docker:
# MANAGEMENT_SERVICE_URL=http://localhost:8080
