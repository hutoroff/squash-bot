# Copy this file to .env and fill in the values below.
# All services share this file. docker-compose.yml (dev) and
# docker-compose.prod.yml (production) both read from it.

# ── Required ────────────────────────────────────────────────────────────────────

# Telegram bot token from https://t.me/BotFather
TELEGRAM_BOT_TOKEN=

# Bot username without @ (e.g. SquashBot). Required by the web service for the Login Widget.
TELEGRAM_BOT_NAME=

# Shared secret that authenticates internal calls between services.
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=

# Secret for signing squash-web session JWTs (HS256, 7-day expiry).
# Generate with: openssl rand -hex 32
JWT_SECRET=

# ── Optional ─────────────────────────────────────────────────────────────────────

# Comma-separated Telegram user IDs allowed to use the /trigger admin command.
# SERVICE_ADMIN_IDS=123456789,987654321

# Cron schedules (evaluated in TIMEZONE below).
# CRON_DAY_BEFORE=0 20 * * *
# CRON_DAY_AFTER=0 8 * * *
# CRON_WEEKLY_REMINDER=0 10 * * 1

# TIMEZONE=UTC
# LOG_LEVEL=INFO


# ── booking ──────────────────────────────────────────────────────────────────────

# URL of the booking service. When set, enables automatic court cancellation
# and auto-booking in management.
# SPORTS_BOOKING_SERVICE_URL=http://booking:8081

# AES-256-GCM key for encrypting venue booking credentials at rest.
# Required to enable the 🔑 Credentials feature in the venue edit menu.
# Generate with: openssl rand -hex 32
# CREDENTIALS_ENCRYPTION_KEY=

# How long a credential must sit out after a booking error before it is retried.
# Accepts Go duration strings (e.g. 24h, 12h30m). Default: 24h.
# CREDENTIAL_ERROR_COOLDOWN=24h

# Eversports account credentials (required if running sports-booking-service).
# EVERSPORTS_EMAIL=
# EVERSPORTS_PASSWORD=

# Eversports facility ID (numeric, visible in the venue page URL on eversports.de).
# Required for GET /api/v1/eversports/games and GET /api/v1/eversports/courts.
# EVERSPORTS_FACILITY_ID=76443

# Facility UUID for booking creation (POST /api/v1/eversports/matches).
# Find it in the facilityUuid field of the /checkout/api/payableitem/courtbooking
# request body in browser DevTools. Has a built-in default for the configured venue.
# EVERSPORTS_FACILITY_UUID=6266968c-b0fd-4115-ad3b-ae225cc880f1

# Sport UUID for booking creation and for /courts. Defaults to the Eversports squash UUID.
# Only change this if you are booking a different sport.
# EVERSPORTS_SPORT_UUID=b388b6e6-69de-11e8-bdc6-02bd505aa7b2

# Facility slug and sport ID for GET /api/v1/eversports/games and GET /api/v1/eversports/courts.
# The slug is the last segment of the venue URL on eversports.de.
# The sport ID is the numeric sport[id] value in the /api/booking/calendar/update request body
# (visible in browser DevTools when opening the booking calendar).
# EVERSPORTS_FACILITY_SLUG=squash-house-berlin-03
# EVERSPORTS_SPORT_ID=496

# Sport slug and name used in the calendar request body. Only change for non-squash sports.
# EVERSPORTS_SPORT_SLUG=squash
# EVERSPORTS_SPORT_NAME=Squash

# ── Production deployment (docker-compose.prod.yml) ───────────────────────────

# PostgreSQL password. Generate with: openssl rand -hex 32
# Used by docker-compose.prod.yml; the dev compose file has its own hardcoded value.
# POSTGRES_PASSWORD=

# Docker Hub username — images are pulled as <username>/squash-management, <username>/squash-telegram-bot, etc.
# DOCKERHUB_USERNAME=

# Docker Hub access token — used by Watchtower to pull updated images without hitting anonymous rate limits.
# Create a read-only token at https://hub.docker.com/settings/security
# DOCKERHUB_TOKEN=

# Pin service image versions (default: latest).
# MANAGEMENT_VERSION=latest
# TELEGRAM_VERSION=latest
# BOOKING_VERSION=latest
# WEB_VERSION=latest

# ── Local development only (not needed when using docker-compose) ────────────────

# Required for management when running outside Docker:
# DATABASE_URL=postgres://squash_bot:squash_bot@localhost:7432/squash_bot

# Required for telegram when running outside Docker:
# MANAGEMENT_SERVICE_URL=http://localhost:8080
