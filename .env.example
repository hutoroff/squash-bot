# Copy this file to .env and fill in the two required values.
# Both services share this file. docker-compose.yml already sets
# DATABASE_URL, SERVER_PORT, and MANAGEMENT_SERVICE_URL, so you
# don't need them here when running via docker-compose.

# ── Required ────────────────────────────────────────────────────────────────────

# Telegram bot token from https://t.me/BotFather
TELEGRAM_BOT_TOKEN=

# Shared secret that authenticates internal calls between the two services.
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=

# ── Optional ─────────────────────────────────────────────────────────────────────

# Comma-separated Telegram user IDs allowed to use the /trigger admin command.
# SERVICE_ADMIN_IDS=123456789,987654321

# Cron schedules (evaluated in TIMEZONE below).
# CRON_DAY_BEFORE=0 20 * * *
# CRON_DAY_AFTER=0 8 * * *
# CRON_WEEKLY_REMINDER=0 10 * * 1

# TIMEZONE=UTC
# LOG_LEVEL=INFO

# ── Local development only (not needed when using docker-compose) ────────────────

# Required for squash-games-management when running outside Docker:
# DATABASE_URL=postgres://squash_bot:squash_bot@localhost:7432/squash_bot

# Required for telegram-squash-bot when running outside Docker:
# MANAGEMENT_SERVICE_URL=http://localhost:8080
